{
  "name": "api-fake",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "types": "./src/types/index.ts",
  "exports": {
    ".": {
      "types": "./src/types/index.ts"
    }
  },
  "bin": {
    "api-fake-browser": "./bin/api-fake-browser.cjs",
    "api-fake-puppeteer": "./bin/api-fake-puppeteer.cjs",
    "api-fake-electron": "./bin/api-fake-electron.cjs"
  },
  "scripts": {
    "CLIENTE    ": "-------------------------------------------------------------------------------",
    "client:dev:wait": "wait-on tcp:3342 && vite",
    "TYPES      ": "-------------------------------------------------------------------------------",
    "SERVER     ": "-------------------------------------------------------------------------------",
    "server:dev": "tsx ./src/server/server.ts",
    "server:dev:watch": "tsx --watch ./src/server/server.ts",
    "PUPPETEER  ": "-------------------------------------------------------------------------------",
    "puppeteer:dev": "wait-on tcp:3343 && NODE_ENV=development tsx ./src/puppeteer/main.ts",
    "ELECTRON   ": "-------------------------------------------------------------------------------",
    "electron:dev": "wait-on tcp:3343 && NODE_ENV=development electron --ozone-platform=x11 --disable-gpu dist/electron/main.js",
    "NPM-SCRIPTS": "-------------------------------------------------------------------------------",
    "dev:with:puppeteer": "concurrently --handle-input --default-input-target 0 --names \"BACKEND,FRONTEND,PUPPETEER\" --prefix-colors \"blue,green,cyan\" --kill-others \"npm:server:dev:watch\" \"npm:client:dev:wait\" \"npm:puppeteer:dev\"",
    "dev:with:electron": "concurrently --handle-input --default-input-target 0 --names \"BACKEND,FRONTEND,ELECTRON\" --prefix-colors \"blue,green,cyan\" --kill-others \"npm:server:dev:watch\" \"npm:client:dev:wait\" \"npm:electron:dev\"",
    "dev:browser": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" --kill-others-on-fail \"npm:server:dev:watch\" \"npm:client:dev\"",
    "lint": "eslint .",
    "COMPILE    ": "-------------------------------------------------------------------------------",
    "build:types": "tsup src/types/index.ts --dts-only --format esm --out-dir dist/types",
    "build:server": "tsup src/server/server.ts --format esm,cjs --dts --out-dir dist/server --tsconfig tsconfig.pack-server.json",
    "build:client": "vite build",
    "build:puppeteer": "tsup src/puppeteer/main.ts --format esm --out-dir dist/puppeteer --tsconfig tsconfig.pack-puppeteer.json --external puppeteer --clean",
    "build:puppeteer:prod-bin": "tsup src/bin/api-fake-puppeteer-prod.ts --format cjs --out-dir dist/bin --tsconfig tsconfig.pack-bin.json && npm run build:puppeteer:prod-bin:fix-shebang",
    "build:puppeteer:prod-bin:fix-shebang": "node ./scripts/fix-cli-shebang.mjs ./dist/bin/api-fake-puppeteer-prod.cjs",
    "build:postinstall": "tsup src/postinstall/postinstall-add-script.ts --format cjs --out-dir dist/scripts --tsconfig tsconfig.pack-postinstall.json",
    "build:electron": "tsup src/electron/main.ts --format esm --out-dir dist/electron --tsconfig tsconfig.pack-electron.json",
    "BUILD      ": "-------------------------------------------------------------------------------",
    "rm-dist": "rm -rfv dist dist-package dist-target",
    "release:build": "npm run build:types && npm run build:server && npm run build:client && npm run build:puppeteer && npm run build:puppeteer:prod-bin && npm run build:postinstall && npm run package:prepare",
    "package:prepare": "node ./scripts/prepare-release-package.mjs",
    "package:pack": "npm run rm-dist && npm run release:build && mkdir -p dist-target && cd dist-package && npm pack --pack-destination ../dist-target",
    "api-fake": "api-fake"
  },
  "dependencies": {
    "axios": "^1.7.8",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remove": "^0.1.5",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/wait-on": "^5.3.4",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "electron": "^42.0.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^15.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1"
  },
  "engines": {
    "node": "^22"
  }
}